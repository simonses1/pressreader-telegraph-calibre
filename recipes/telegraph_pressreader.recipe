#!/usr/bin/env python
# vim:fileencoding=utf-8
'''
The Daily Telegraph via PressReader.

This recipe is intentionally a thin Calibre wrapper around
scripts/pressreader_textview_prefetch.py. PressReader's Library/HotSpot sign-in
and TextView app require a real browser session, so the helper performs that
work and writes a manifest of local article HTML files for Calibre to ingest.
'''

import json
import os
import subprocess
import sys
from collections import OrderedDict
from datetime import datetime
from pathlib import Path

from calibre.web.feeds.news import BasicNewsRecipe


DEFAULT_PROJECT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), '..')) if '__file__' in globals() else os.getcwd()
DEFAULT_PYTHON = '/Library/Frameworks/Python.framework/Versions/3.10/bin/python3.10'


class TelegraphPressReader(BasicNewsRecipe):
    title = 'The Daily Telegraph'
    __author__ = 'Simon Stace'
    description = 'The Daily Telegraph from PressReader TextView with Surrey Libraries authentication.'
    language = 'en_GB'
    publisher = 'The Telegraph'
    category = 'newspaper, telegraph, pressreader'
    encoding = 'utf-8'
    needs_subscription = 'optional'
    no_stylesheets = True
    remove_javascript = True
    remove_attributes = ['style', 'width', 'height']
    remove_empty_feeds = True
    ignore_duplicate_articles = {'url'}
    articles_are_obfuscated = True
    simultaneous_downloads = 1
    timeout = 120

    recipe_specific_options = {
        'manifest': {
            'short': 'Existing manifest',
            'long': 'Optional path to an already-prefetched manifest.json.',
        },
        'issue_date': {
            'short': 'Issue date',
            'long': 'PressReader issue date in YYYYMMDD format. Defaults to today.',
        },
        'env_file': {
            'short': 'Credential env file',
            'long': 'Path to .env.pressreader. Defaults to the project .env.pressreader.',
        },
        'project_dir': {
            'short': 'Project directory',
            'long': 'Repository root containing scripts/pressreader_textview_prefetch.py. Defaults to this recipe parent, cwd, or PRESSREADER_CALIBRE_PROJECT_DIR.',
        },
        'profile_dir': {
            'short': 'Browser profile',
            'long': 'Persistent Chromium profile directory for PressReader.',
        },
        'out_dir': {
            'short': 'Prefetch output directory',
            'long': 'Directory for helper output. Defaults to /tmp/pressreader-telegraph-YYYYMMDD.',
        },
        'helper_script': {
            'short': 'Prefetch helper script',
            'long': 'Path to scripts/pressreader_textview_prefetch.py.',
        },
        'python': {
            'short': 'Python executable',
            'long': 'Python with Playwright installed.',
        },
        'limit': {
            'short': 'Article limit',
            'long': 'Optional article limit for testing. Omit for the full issue.',
        },
        'image_scale': {
            'short': 'Image scale',
            'long': 'PressReader image scale. Defaults to 200. Use 100 for smaller files or 300 for larger images.',
        },
        'cover_width': {
            'short': 'Cover width',
            'long': 'PressReader front-page cover width in pixels. Defaults to 1000.',
        },
        'debug': {
            'short': 'Keep debug artefacts',
            'long': 'Set to 1/true/yes to keep helper debug artefacts.',
        },
    }

    conversion_options = {
        'comment': description,
        'tags': category,
        'publisher': publisher,
        'language': language,
    }

    extra_css = '''
body { font-family: serif; line-height: 1.35; }
img { display: block; margin: 1em auto; max-width: 100%; height: auto; }
.source, .meta { font-size: small; color: #555; }
.subtitle { font-weight: bold; }
'''

    def __init__(self, options, log, progress_reporter):
        self._early_recipe_options = {}
        self._manifest_base_dir = ''
        self._prefetched_articles = {}
        for raw in (getattr(options, 'recipe_specific_option', None) or ()):
            key, sep, value = raw.partition(':')
            if sep:
                self._early_recipe_options[key] = value
        BasicNewsRecipe.__init__(self, options, log, progress_reporter)

    def _option(self, name):
        value = self._early_recipe_options.get(name)
        if value is None and isinstance(self.recipe_specific_options, dict):
            spec = self.recipe_specific_options.get(name)
            if isinstance(spec, dict):
                value = spec.get('default')
        return value

    def _truthy_option(self, name):
        value = (self._option(name) or '').strip().lower()
        return value in {'1', 'true', 'yes', 'y', 'on'}

    def _issue_date(self):
        value = (self._option('issue_date') or '').strip()
        if value:
            if len(value) != 8 or not value.isdigit():
                raise ValueError(f'PressReader issue_date must be YYYYMMDD, got: {value}')
            return value
        return datetime.now().strftime('%Y%m%d')

    def _project_dir(self):
        explicit = self._option('project_dir') or os.environ.get('PRESSREADER_CALIBRE_PROJECT_DIR')
        if explicit:
            return os.path.abspath(os.path.expanduser(explicit))
        candidates = []
        if '__file__' in globals():
            try:
                candidates.append(str(Path(__file__).resolve().parent.parent))
            except Exception:
                pass
        candidates.extend([os.getcwd(), DEFAULT_PROJECT_DIR])
        for candidate in candidates:
            if candidate and os.path.exists(os.path.join(candidate, 'scripts', 'pressreader_textview_prefetch.py')):
                return os.path.abspath(os.path.expanduser(candidate))
        return DEFAULT_PROJECT_DIR

    def _default_path(self, option_name, *parts):
        value = self._option(option_name)
        if value:
            return os.path.abspath(os.path.expanduser(value))
        return os.path.join(self._project_dir(), *parts)

    def _python_executable(self):
        value = self._option('python') or os.environ.get('PRESSREADER_PYTHON') or DEFAULT_PYTHON
        value = os.path.expanduser(value)
        if os.path.exists(value):
            return value
        return sys.executable or 'python3'

    def _manifest_path(self):
        value = self._option('manifest')
        if value:
            path = os.path.abspath(os.path.expanduser(value))
            if not os.path.exists(path):
                raise ValueError(f'PressReader manifest does not exist: {path}')
            return path
        return self._run_prefetch()

    def _run_prefetch(self):
        issue_date = self._issue_date()
        helper = self._default_path('helper_script', 'scripts', 'pressreader_textview_prefetch.py')
        env_file = self._default_path('env_file', '.env.pressreader')
        profile_dir = os.path.abspath(os.path.expanduser(
            self._option('profile_dir') or '~/.pressreader-surrey-library-profile'
        ))
        out_dir = os.path.abspath(os.path.expanduser(
            self._option('out_dir') or f'/tmp/pressreader-telegraph-{issue_date}'
        ))
        url = f'https://www.pressreader.com/uk/the-daily-telegraph/{issue_date}/textview'

        if not os.path.exists(helper):
            raise ValueError(f'PressReader helper script does not exist: {helper}')
        if not os.path.exists(env_file):
            raise ValueError(f'PressReader env file does not exist: {env_file}')

        cmd = [
            self._python_executable(),
            helper,
            '--env-file', env_file,
            '--library-login',
            '--headless',
            '--profile-dir', profile_dir,
            '--out-dir', out_dir,
            '--url', url,
        ]
        limit = (self._option('limit') or '').strip()
        if limit:
            cmd.extend(['--limit', limit])
        image_scale = (self._option('image_scale') or '200').strip()
        if image_scale:
            if not image_scale.isdigit():
                raise ValueError(f'PressReader image_scale must be numeric, got: {image_scale}')
            cmd.extend(['--image-scale', image_scale])
        cover_width = (self._option('cover_width') or '1000').strip()
        if cover_width:
            if not cover_width.isdigit():
                raise ValueError(f'PressReader cover_width must be numeric, got: {cover_width}')
            cmd.extend(['--cover-width', cover_width])
        if self._truthy_option('debug'):
            cmd.append('--debug')

        self.log('Running PressReader prefetch for', issue_date)
        proc_env = dict(os.environ)
        proc_env.setdefault('PYTHONIOENCODING', 'utf-8')
        completed = subprocess.run(
            cmd,
            cwd=self._project_dir(),
            env=proc_env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=300,
        )
        for line in (completed.stderr or '').splitlines():
            self.log('PressReader:', line)
        if completed.returncode:
            raise ValueError(
                'PressReader prefetch failed with exit code %s. Last output: %s'
                % (completed.returncode, (completed.stderr or completed.stdout or '').splitlines()[-8:])
            )

        manifest = os.path.join(out_dir, 'manifest.json')
        for line in reversed((completed.stdout or '').splitlines()):
            if line.strip().endswith('manifest.json'):
                manifest = line.strip()
                break
        if not os.path.exists(manifest):
            raise ValueError(f'PressReader prefetch completed but manifest was not found: {manifest}')
        return os.path.abspath(manifest)

    def _load_manifest(self):
        manifest_path = self._manifest_path()
        self._manifest_base_dir = os.path.dirname(manifest_path)
        with open(manifest_path, 'r', encoding='utf-8') as f:
            manifest = json.load(f)
        articles = manifest.get('articles') if isinstance(manifest, dict) else manifest
        if not isinstance(articles, list):
            raise ValueError('PressReader manifest must contain an articles list')
        if not articles:
            raise ValueError(f'PressReader manifest contained no articles: {manifest_path}')
        cover_url = manifest.get('cover_url') or manifest.get('cover') if isinstance(manifest, dict) else ''
        if cover_url:
            self.cover_url = cover_url
            self._prefetched_cover_url = cover_url
            self.log('Using PressReader front-page cover:', cover_url)
        self.log('Using PressReader manifest', manifest_path)
        return articles

    def parse_index(self):
        articles = self._load_manifest()
        feeds = OrderedDict()
        for index, article in enumerate(articles, 1):
            if not isinstance(article, dict):
                continue
            title = (article.get('title') or f'Article {index}').strip()
            html_path = article.get('html') or ''
            if html_path and not os.path.isabs(html_path):
                html_path = os.path.join(self._manifest_base_dir, html_path)
            if not html_path or not os.path.exists(html_path):
                raise ValueError(f'PressReader article HTML does not exist for {title}: {html_path}')
            url = article.get('url') or f'pressreader-prefetched://article/{index}'
            section = (article.get('section') or 'Articles').strip() or 'Articles'
            cached = dict(article)
            cached['html_path'] = html_path
            self._prefetched_articles[url] = cached
            feeds.setdefault(section, []).append({'title': title, 'url': url})
        if not feeds:
            raise ValueError('PressReader manifest contained no usable articles')
        self.log('Loaded', sum(len(x) for x in feeds.values()), 'Telegraph articles from PressReader')
        return list(feeds.items())

    def get_obfuscated_article(self, url):
        article = self._prefetched_articles.get(url)
        if not article:
            raise ValueError(f'PressReader manifest article was not cached: {url}')
        html_path = article['html_path']
        with open(html_path, 'rb') as f:
            data = f.read()
        return {
            'data': data,
            'url': article.get('base_url') or Path(html_path).resolve().as_uri(),
        }

    def get_cover_url(self):
        return getattr(self, '_prefetched_cover_url', None) or getattr(self, 'cover_url', None)
